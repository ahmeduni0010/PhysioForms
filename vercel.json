{
  "version": 2,
  "cleanUrls": true,
  "public": true,
  "routes": [
    {
      "src": "/css/(.*)",
      "dest": "/public/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1"
    },
    {
      "src": "/index.html",
      "dest": "/public/index.html"
    },
    {
      "src": "/dashboard.html",
      "dest": "/public/dashboard.html"
    },
    {
      "src": "/form.html",
      "dest": "/public/form.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}